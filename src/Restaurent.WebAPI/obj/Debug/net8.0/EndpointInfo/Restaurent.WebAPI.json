    "/api/Home/add-dish": {
      "post": {
        "tags": [
          "Home"
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "required": [
                  "CategoryId",
                  "Description",
                  "Dish_Image",
                  "DishName",
                  "Price"
                ],
                "type": "object",
                "properties": {
                  "DishName": {
                    "maxLength": 40,
                    "minLength": 0,
                    "type": "string"
                  },
                  "Price": {
                    "type": "number",
                    "format": "currency"
                  },
                  "Description": {
                    "maxLength": 600,
                    "minLength": 0,
                    "type": "string"
                  },
                  "CategoryId": {
                    "type": "string"
                  },
                  "Dish_Image": {
                    "type": "string",
                    "format": "binary"
                  },
                  "ImagePath_url": {
                    "type": "string"
                  }
                }
              },
              "encoding": {
                "DishName": {
                  "style": "form"
                },
                "Price": {
                  "style": "form"
                },
                "Description": {
                  "style": "form"
                },
                "CategoryId": {
                  "style": "form"
                },
                "Dish_Image": {
                  "style": "form"
                },
                "ImagePath_url": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Home": {
      "put": {
        "tags": [
          "Home"
        ],
        "parameters": [
          {
            "name": "DishId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "DishName",
            "in": "query",
            "required": true,
            "schema": {
              "maxLength": 40,
              "minLength": 0,
              "type": "string"
            }
          },
          {
            "name": "Price",
            "in": "query",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "currency"
            }
          },
          {
            "name": "Description",
            "in": "query",
            "required": true,
            "schema": {
              "maxLength": 600,
              "minLength": 0,
              "type": "string"
            }
          },
          {
            "name": "CategoryId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "Image_Path",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "Dish_Image": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              },
              "encoding": {
                "Dish_Image": {
                  "style": "form"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Home/{dishId}": {
      "delete": {
        "tags": [
          "Home"
        ],
        "parameters": [
          {
            "name": "dishId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
